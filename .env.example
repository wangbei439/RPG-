# ===== Server Configuration =====
PORT=3000
NODE_ENV=development

# ===== Authentication =====
# Set a password for admin access (required for production)
ADMIN_PASSWORD=
# Disable authentication entirely (development only)
AUTH_DISABLED=true
# JWT secret key (auto-generated if not set, but set for production)
JWT_SECRET=
# JWT token expiration (default: 7d)
JWT_EXPIRES_IN=7d

# ===== Rate Limiting =====
# Disable rate limiting (development only)
RATE_LIMIT_DISABLED=false

# ===== LLM Configuration =====
LLM_SOURCE=openai
OPENAI_API_KEY=
OPENAI_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ===== Image Generation =====
IMAGE_SOURCE=none
COMFYUI_URL=http://127.0.0.1:8000
COMFY_WORKFLOWS_DIR=
IMAGE_API_URL=
IMAGE_API_KEY=

# ===== Database =====
# SQLite database path (default: backend/data/rpg.db)
# DB_PATH=

# ===== ManasDB =====
# See backend/manasdb-config.json for ManasDB configuration
