{
    "env": {
        "browser": true,
        "es2022": true
    },
    "extends": ["eslint:recommended"],
    "parserOptions": {
        "ecmaVersion": "latest",
        "sourceType": "module"
    },
    "rules": {
        "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
        "no-console": "warn",
        "prefer-const": "warn",
        "no-var": "error",
        "eqeqeq": ["error", "always"],
        "no-template-curly-in-string": "error",
        "no-unreachable": "error"
    }
}
